# All APIs work WITHOUT keys. These are optional enhancements.

# Optional: Mapillary client token for street-level photos (free signup at https://mapillary.com/developer)
MAPILLARY_CLIENT_TOKEN=

# Optional: Google Street View API key (requires billing-enabled Google Cloud account)
# When set, actual Street View images are fetched and embedded inline with copy/download.
# Without it, a clickable link to Google Maps Street View is shown instead.
GOOGLE_STREETVIEW_API_KEY=
